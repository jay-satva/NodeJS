        "summary": "Update task status",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "orgId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "projectId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "taskId", "in": "path", "required": true, "schema": { "type": "string" } }

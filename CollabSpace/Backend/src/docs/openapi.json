            "application/json": { "schema": { "$ref": "#/components/schemas/TagUpdateRequest" } }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } }

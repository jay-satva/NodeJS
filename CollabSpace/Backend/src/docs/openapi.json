        "parameters": [
          { "name": "orgId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "includeArchived", "in": "query", "required": false, "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } }
        }
      },
      "post": {
        "tags": ["Projects"],
        "summary": "Create project (MANAGER/ADMIN/SUPER_ADMIN)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "orgId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],

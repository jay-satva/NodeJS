          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ProjectCreateRequest" } }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } }
        }

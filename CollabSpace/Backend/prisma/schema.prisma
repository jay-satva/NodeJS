generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GlobalRole {
  SUPER_ADMIN
  USER
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum TaskStatus {
  BACKLOG
  ONGOING
  DEVELOPMENT_COMPLETED
  UNIT_TESTING
  QA
  QA_COMPLETED
  COMPLETED
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  globalRole        GlobalRole         @default(USER)
  orgMembers        OrgMember[]
  taskAssignments   TaskAssignment[]
  comments          Comment[]
  activityLogs      ActivityLog[]
  createdProjects   Project[]          @relation("ProjectCreator")
  previousAssignments AssignmentHistory[] @relation("PreviousUser")
  newAssignments      AssignmentHistory[] @relation("NewUser")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())

  members  OrgMember[]
  projects Project[]
  tags     Tag[]
}

model OrgMember {
  userId   String   @db.Uuid
  orgId    String   @db.Uuid
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([userId, orgId]) 
  
}

model Project {
  id         String    @id @default(uuid()) @db.Uuid
  title      String
  archived   Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  orgId      String    @db.Uuid
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdBy  String    @db.Uuid
  creator    User      @relation("ProjectCreator", fields: [createdBy], references: [id])

  tasks      Task[]

  @@unique([title, orgId]) 
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  description String
  status      TaskStatus @default(BACKLOG)
  archived    Boolean    @default(false)
  archivedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  projId      String     @db.Uuid
  project     Project    @relation(fields: [projId], references: [id], onDelete: Restrict)

  comments          Comment[]
  activityLogs      ActivityLog[]
  assignmentHistory AssignmentHistory[]
  assignments       TaskAssignment[]
  tags              TaskTag[]

  @@unique([title, projId]) 
}

model TaskAssignment {
  taskId      String   @db.Uuid
  userId      String   @db.Uuid
  assignedAt  DateTime @default(now())

  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  message   String
  createdAt DateTime @default(now())

  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId    String   @db.Uuid
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String     @id @default(uuid()) @db.Uuid
  oldStatus TaskStatus
  newStatus TaskStatus
  createdAt DateTime   @default(now())

  taskId    String     @db.Uuid
  task      Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId    String     @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AssignmentHistory {
  id           String   @id @default(uuid()) @db.Uuid
  timeOfChange DateTime @default(now())

  taskId       String   @db.Uuid
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  previousUserId String? @db.Uuid
  previousUser   User?   @relation("PreviousUser", fields: [previousUserId], references: [id], onDelete: SetNull)

  newUserId    String?  @db.Uuid
  newUser      User?    @relation("NewUser", fields: [newUserId], references: [id], onDelete: SetNull)
}

model Tag {
  id    String @id @default(uuid()) @db.Uuid
  name  String

  orgId String @db.Uuid
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  tasks TaskTag[]

  @@unique([name, orgId]) 
}

model TaskTag {
  taskId String @db.Uuid
  tagId  String @db.Uuid

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}
